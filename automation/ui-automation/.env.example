INVENTREE_BASE_URL=https://demo.inventree.org

# Login credentials
# Evidence: login_page.png shows Username="allaccess" Password="nolimits" (demo instance)
INVENTREE_USERNAME=allaccess
INVENTREE_PASSWORD=nolimits
